---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '~/components/FormattedDate.astro';

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { data } = entry;
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  published={data.date}
>
  <article class="post container">
    <header class="post-header">
      <h1 class="post-title">{data.title}</h1>
      <div class="post-meta">
        <FormattedDate date={data.date} />
        {
          data.category && (
            <>
              <span class="sep">·</span>
              <a href={`/categories/${data.category}/`} class="meta-link">
                {data.category}
              </a>
            </>
          )
        }
        {
          data.tags?.length > 0 && (
            <>
              <span class="sep">·</span>
              <span class="tags">
                {data.tags.map((t) => (
                  <a class="tag" href={`/tags/${t}/`}>#{t}</a>
                ))}
              </span>
            </>
          )
        }
      </div>
    </header>

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/posts/" class="post-back">← 返回文章列表</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post { padding-top: 3rem; }
  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .post-title {
    font-size: 2rem;
    margin: 0 0 0.8rem;
    line-height: 1.25;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-subtle);
    font-size: 0.9rem;
  }
  .sep { opacity: 0.5; }
  .meta-link, .tag {
    color: var(--text-muted);
  }
  .meta-link:hover, .tag:hover { color: var(--accent); }
  .tags { display: inline-flex; gap: 0.5rem; flex-wrap: wrap; }
  .post-content :global(img) {
    margin: 1.5em auto;
    box-shadow: var(--shadow);
  }
  .post-content :global(h2) {
    margin-top: 2.4em;
    padding-top: 0.4em;
  }
  .post-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .post-back {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .post-back:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .post-title { font-size: 1.5rem; }
  }
</style>
