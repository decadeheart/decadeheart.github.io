---
import BaseLayout from '~/layouts/BaseLayout.astro';
import {
  CONTACT,
  SUMMARY,
  EDUCATION,
  EXPERIENCE,
  PROJECTS,
  SKILLS,
  AWARDS,
  RESUME_VERSION,
} from '~/data/resume';
import { PUBLICATIONS } from '~/data/publications';

const sortedPubs = [...PUBLICATIONS].sort((a, b) => {
  if (b.year !== a.year) return b.year - a.year;
  return (b.month ?? 0) - (a.month ?? 0);
});
---

<BaseLayout
  title={`CV · ${CONTACT.name}`}
  description={`${CONTACT.name} · 求职简历`}
>
  <article class="cv container">
    <div class="cv-toolbar no-print">
      <span class="version">v{RESUME_VERSION}</span>
      <button class="tool-btn" type="button" id="print-btn">导出 PDF</button>
    </div>

    <header class="cv-head">
      <div>
        <h1 class="cv-name">
          {CONTACT.name}
          {CONTACT.nameZh && <span class="cv-name-zh">{CONTACT.nameZh}</span>}
        </h1>
        <p class="cv-title">{CONTACT.title}</p>
      </div>
      <div class="cv-contact">
        <div>{CONTACT.location}</div>
        <div><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></div>
        <div class="cv-links">
          {
            CONTACT.links.map((l, i) => (
              <>
                <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                {i < CONTACT.links.length - 1 && <span> · </span>}
              </>
            ))
          }
        </div>
      </div>
    </header>

    <section class="cv-block">
      <h2 class="cv-h">Summary</h2>
      <p class="cv-summary">{SUMMARY}</p>
    </section>

    <section class="cv-block">
      <h2 class="cv-h">Education</h2>
      {
        EDUCATION.map((e) => (
          <div class="entry">
            <div class="entry-head">
              <div>
                <strong>{e.org}</strong>
                {e.orgZh && <span class="zh"> · {e.orgZh}</span>}
              </div>
              <div class="period">{e.period}</div>
            </div>
            <div class="entry-sub">
              <span>{e.degree}</span>
              {e.dept && <span class="sep"> · </span>}
              {e.dept && <span>{e.dept}</span>}
              <span class="sep"> · </span>
              <span>{e.location}</span>
            </div>
            {e.bullets?.length && (
              <ul class="bullets">
                {e.bullets.map((b) => <li>{b}</li>)}
              </ul>
            )}
          </div>
        ))
      }
    </section>

    {
      EXPERIENCE.length > 0 && (
        <section class="cv-block">
          <h2 class="cv-h">Appointments & Experience</h2>
          {EXPERIENCE.map((e) => (
            <div class="entry">
              <div class="entry-head">
                <div>
                  <strong>{e.role}</strong>
                  <span class="sep"> @ </span>
                  <span>{e.org}</span>
                </div>
                <div class="period">{e.period}</div>
              </div>
              {e.location && <div class="entry-sub">{e.location}</div>}
              <ul class="bullets">
                {e.bullets.map((b) => <li>{b}</li>)}
              </ul>
              {e.tech?.length && (
                <div class="tech">
                  {e.tech.map((t) => <span class="tech-chip">{t}</span>)}
                </div>
              )}
            </div>
          ))}
        </section>
      )
    }

    <section class="cv-block">
      <h2 class="cv-h">Selected Publications</h2>
      <ol class="pub-list">
        {
          sortedPubs.map((p) => (
            <li>
              <span class="pub-title-mini">{p.title}</span>{' '}
              <span class="pub-meta">
                {p.authors.map((a, i) => (
                  <>
                    <span class:list={{ 'is-me': a.me }}>{a.name}</span>
                    {i < p.authors.length - 1 && ', '}
                  </>
                ))}
                .{' '}
                <em>{p.venueShort ?? p.venue}</em>, {p.year}
                {p.doi && (
                  <>
                    {' · '}
                    <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">
                      doi:{p.doi}
                    </a>
                  </>
                )}
              </span>
            </li>
          ))
        }
      </ol>
    </section>

    {
      PROJECTS.length > 0 && (
        <section class="cv-block">
          <h2 class="cv-h">Projects</h2>
          {PROJECTS.map((p) => (
            <div class="entry">
              <div class="entry-head">
                <div>
                  <strong>{p.name}</strong>
                  {p.link && (
                    <>
                      <span class="sep"> · </span>
                      <a href={p.link} target="_blank" rel="noopener">
                        link
                      </a>
                    </>
                  )}
                </div>
                {p.period && <div class="period">{p.period}</div>}
              </div>
              <div class="entry-sub">{p.description}</div>
              {p.bullets?.length && (
                <ul class="bullets">
                  {p.bullets.map((b) => <li>{b}</li>)}
                </ul>
              )}
              {p.tech?.length && (
                <div class="tech">
                  {p.tech.map((t) => <span class="tech-chip">{t}</span>)}
                </div>
              )}
            </div>
          ))}
        </section>
      )
    }

    <section class="cv-block">
      <h2 class="cv-h">Skills</h2>
      <dl class="skills">
        {
          SKILLS.map((s) => (
            <>
              <dt>{s.group}</dt>
              <dd>{s.items.join(' · ')}</dd>
            </>
          ))
        }
      </dl>
    </section>

    {
      AWARDS.length > 0 && (
        <section class="cv-block">
          <h2 class="cv-h">Awards & Honors</h2>
          <ul class="awards">
            {AWARDS.map((a) => (
              <li>
                <span class="award-year">{a.year}</span>
                <span class="award-title">{a.title}</span>
                {a.detail && <span class="award-detail"> — {a.detail}</span>}
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .cv {
    padding: 2.5rem 0 4rem;
    max-width: 820px;
  }

  .cv-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px dashed var(--border);
  }
  .version {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-subtle);
  }
  .tool-btn {
    background: var(--accent);
    color: #fff;
    border: 0;
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 0.85rem;
    cursor: pointer;
    font-family: var(--font-sans);
  }
  .tool-btn:hover { background: var(--accent-hover); }

  .cv-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--text);
  }
  .cv-name {
    font-size: 1.9rem;
    margin: 0 0 0.25rem;
    line-height: 1.15;
  }
  .cv-name-zh {
    margin-left: 0.5rem;
    color: var(--text-muted);
    font-weight: 500;
    font-size: 1.3rem;
  }
  .cv-title {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.95rem;
  }
  .cv-contact {
    text-align: right;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .cv-contact a { color: var(--text-muted); }
  .cv-contact a:hover { color: var(--accent); }
  .cv-links { font-size: 0.82rem; }

  .cv-block {
    margin-top: 1.5rem;
  }
  .cv-h {
    font-size: 1.05rem;
    margin: 0 0 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
  }

  .cv-summary { line-height: 1.7; margin: 0; color: var(--text); }

  .entry {
    margin: 0.8rem 0 1.2rem;
  }
  .entry-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .period {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    white-space: nowrap;
  }
  .entry-sub {
    color: var(--text-muted);
    font-size: 0.88rem;
    margin: 0.15rem 0 0.4rem;
  }
  .sep { color: var(--text-subtle); }
  .zh { color: var(--text-muted); font-weight: 500; }
  .bullets {
    list-style: disc;
    padding-left: 1.3em;
    margin: 0.3rem 0;
  }
  .bullets li { line-height: 1.65; margin: 0.15em 0; }
  .tech {
    margin-top: 0.4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .tech-chip {
    display: inline-block;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 8px;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .pub-list {
    padding-left: 1.4em;
    margin: 0;
  }
  .pub-list li {
    margin: 0.5em 0;
    line-height: 1.6;
  }
  .pub-title-mini { color: var(--text); font-weight: 500; }
  .pub-meta { color: var(--text-muted); font-size: 0.88rem; }
  .pub-meta em { font-style: italic; color: var(--text); }
  .is-me {
    color: var(--text);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 2px;
  }
  .pub-meta a { color: var(--text-muted); text-decoration: underline; }
  .pub-meta a:hover { color: var(--accent); }

  .skills {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 0.5rem 1rem;
    margin: 0;
  }
  .skills dt {
    font-weight: 600;
    color: var(--accent);
    font-size: 0.9rem;
  }
  .skills dd {
    margin: 0;
    color: var(--text);
    font-size: 0.92rem;
  }

  .awards {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .awards li {
    padding: 0.25rem 0;
    display: flex;
    gap: 1rem;
  }
  .award-year {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    min-width: 3.5rem;
  }
  .award-title { color: var(--text); }
  .award-detail { color: var(--text-muted); }

  @media (max-width: 640px) {
    .cv-head { flex-direction: column; align-items: stretch; }
    .cv-contact { text-align: left; }
    .skills { grid-template-columns: 1fr; gap: 0.1rem; }
    .skills dt { margin-top: 0.5rem; }
  }

  /* Print: hide site chrome, tighten layout, keep accent colors */
  @media print {
    :global(header.header),
    :global(footer.footer),
    :global(.skip-link),
    .no-print {
      display: none !important;
    }
    :global(body) {
      background: #fff !important;
      color: #000 !important;
      font-size: 10.5pt;
    }
    .cv {
      padding: 0;
      max-width: none;
    }
    .cv-block { margin-top: 0.8rem; page-break-inside: avoid; }
    .entry { page-break-inside: avoid; }
    .cv-h { color: #b8512a !important; }
    a { color: #000 !important; text-decoration: none !important; }
    .is-me { text-decoration: underline !important; }
  }
</style>

<script>
  const btn = document.getElementById('print-btn');
  btn?.addEventListener('click', () => window.print());
</script>
